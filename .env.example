# Aeris project-level environment configuration
# Copy this file to `.env`, then fill in the values you actually want to use.
#
# Recommended setup:
# 1. Pick an active provider with `AERIS_ACTIVE_PROVIDER`
# 2. Set the matching API key for that provider
# 3. Leave the provider model unset if you prefer switching models from `/model` in the CLI

# Optional
# Active provider used by Aeris at runtime: `claude` or `openrouter`
AERIS_ACTIVE_PROVIDER=claude

# Claude / Anthropic
AERIS_CLAUDE_API_KEY=your_claude_api_key
# AERIS_CLAUDE_BASE_URL=https://your-gateway.example.com/v1
AERIS_CLAUDE_BASE_URL=https://api.anthropic.com/v1
# AERIS_CLAUDE_MODEL=claude-sonnet-4-20250514

# OpenRouter
# You can also use OPENROUTER_API_KEY as a fallback env var name.
# AERIS_OPENROUTER_API_KEY=your_openrouter_api_key
AERIS_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# AERIS_OPENROUTER_MODEL=provider/model-name
AERIS_OPENROUTER_MODEL=provider/model-name
AERIS_OPENROUTER_API_KEY = your_openrouter_api_key
# Optional
# Enable or disable automatic project-context injection
# true = on, false = off
AERIS_PROJECT_CONTEXT_ENABLED=true
