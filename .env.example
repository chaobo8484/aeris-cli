# Odradek project-level environment configuration
# Copy this file to `.env`, then fill in the values you actually want to use.
#
# Recommended setup:
# 1. Pick an active provider with `ODRADEK_ACTIVE_PROVIDER`
# 2. Set the matching API key for that provider
# 3. Leave the provider model unset if you prefer switching models from `/model` in the CLI

# Optional
# Active provider used by Odradek at runtime: `claude` or `openrouter`
ODRADEK_ACTIVE_PROVIDER=claude

# Claude / Anthropic
ODRADEK_CLAUDE_API_KEY=your_claude_api_key
# ODRADEK_CLAUDE_BASE_URL=https://your-gateway.example.com/v1
ODRADEK_CLAUDE_BASE_URL=https://api.anthropic.com/v1
# ODRADEK_CLAUDE_MODEL=claude-sonnet-4-20250514

# OpenRouter
# You can also use OPENROUTER_API_KEY as a fallback env var name.
# ODRADEK_OPENROUTER_API_KEY=your_openrouter_api_key
ODRADEK_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# ODRADEK_OPENROUTER_MODEL=provider/model-name
ODRADEK_OPENROUTER_MODEL=provider/model-name
ODRADEK_OPENROUTER_API_KEY = your_openrouter_api_key
# Optional
# Enable or disable automatic project-context injection
# true = on, false = off
ODRADEK_PROJECT_CONTEXT_ENABLED=true
